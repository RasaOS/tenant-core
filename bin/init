#!/usr/bin/env bash
#
# rasa.domain.core init — minimal canonical installer for the
# domain Element template.
#
# Usage:
#   bin/init [target-dir]
#
# If [target-dir] is omitted, the current working directory is used.
#
# This script is the Element-primitive installer per canon
# ELEMENT_CONTRACT.md §7 (install policies). What gets installed
# is declared entirely in rasa.json — this script holds NO
# hardcoded file list. It reads the Connection Contract and applies
# each entry in element.files[] and seed.files[] by its declared
# policy.
#
# For domain-core v0.1.0 specifically: element.files[] is empty
# (template ships zero domain content). seed.files[] has the two
# canonical templates (CLAUDE.md.template + rasa.lock.json.template).
# So an init here mainly writes the lockfile + the project CLAUDE.md.

set -euo pipefail

# ---------- Paths + args ----------

ELEMENT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TARGET="${1:-$(pwd)}"
TARGET="$(cd "$TARGET" && pwd)"

if [[ "$TARGET" == "$ELEMENT_DIR" ]]; then
  echo "✗ Refusing to install into the Element's own folder." >&2
  echo "  Per ELEMENT_CONTRACT — Elements don't install into themselves." >&2
  exit 1
fi

# ---------- Read rasa.json ----------

MANIFEST="$ELEMENT_DIR/rasa.json"

if [[ ! -f "$MANIFEST" ]]; then
  echo "✗ rasa.json not found at $MANIFEST" >&2
  exit 1
fi

# Resolve Element identity for lockfile stamping
ELEMENT_NAME="$(python3 -c "import json; print(json.load(open('$MANIFEST'))['name'])")"
ELEMENT_KIND="$(python3 -c "import json; print(json.load(open('$MANIFEST'))['kind'])")"
ELEMENT_VERSION="$(python3 -c "import json; print(json.load(open('$MANIFEST'))['version'])")"
ELEMENT_REPO="$(python3 -c "import json; print(json.load(open('$MANIFEST'))['source']['repo'])")"
ELEMENT_BRANCH="$(python3 -c "import json; print(json.load(open('$MANIFEST'))['source']['branch'])")"

# Resolve current Element SHA
ELEMENT_SHA="$(git -C "$ELEMENT_DIR" rev-parse HEAD 2>/dev/null || echo "uncommitted")"
TODAY="$(date -u +%Y-%m-%d)"

echo "→ Installing $ELEMENT_NAME @ $ELEMENT_VERSION ($ELEMENT_SHA)"
echo "  into: $TARGET"
echo ""

# ---------- Apply element.files[] ----------

count_elem="$(python3 -c "import json; print(len(json.load(open('$MANIFEST')).get('element', {}).get('files', [])))")"

if [[ "$count_elem" -eq 0 ]]; then
  echo "  element.files[] empty — domain-core v0.x ships zero content."
else
  echo "  Applying $count_elem element.files[] entries..."
  python3 - "$MANIFEST" "$ELEMENT_DIR" "$TARGET" <<'PYEOF'
import json, os, shutil, sys

manifest_path, element_dir, target = sys.argv[1], sys.argv[2], sys.argv[3]
manifest = json.load(open(manifest_path))

for entry in manifest.get('element', {}).get('files', []):
    src = os.path.join(element_dir, entry['from'])
    dst = os.path.join(target, entry['to'])
    policy = entry['policy']
    os.makedirs(os.path.dirname(dst), exist_ok=True)
    if policy == 'directory-mirror':
        if os.path.isdir(src):
            shutil.copytree(src, dst, dirs_exist_ok=True)
    elif policy == 'file-replace':
        shutil.copy2(src, dst)
    elif policy == 'opt-in':
        pass  # not installed automatically
    else:
        print(f"  ⚠ unknown element.files[] policy: {policy} for {entry['from']}", file=sys.stderr)
PYEOF
fi

# ---------- Apply seed.files[] ----------

count_seed="$(python3 -c "import json; print(len(json.load(open('$MANIFEST')).get('seed', {}).get('files', [])))")"

if [[ "$count_seed" -eq 0 ]]; then
  echo "  seed.files[] empty — no one-time files to copy."
else
  echo "  Applying $count_seed seed.files[] entries..."
  python3 - "$MANIFEST" "$ELEMENT_DIR" "$TARGET" \
    "$ELEMENT_NAME" "$ELEMENT_KIND" "$ELEMENT_VERSION" \
    "$ELEMENT_REPO" "$ELEMENT_BRANCH" "$ELEMENT_SHA" "$TODAY" <<'PYEOF'
import json, os, shutil, sys

(manifest_path, element_dir, target,
 elem_name, elem_kind, elem_version,
 elem_repo, elem_branch, elem_sha, today) = sys.argv[1:11]

manifest = json.load(open(manifest_path))

subs = {
    '{{ELEMENT_NAME}}':    elem_name,
    '{{ELEMENT_KIND}}':    elem_kind,
    '{{ELEMENT_VERSION}}': elem_version,
    '{{ELEMENT_REPO}}':    elem_repo,
    '{{ELEMENT_BRANCH}}':  elem_branch,
    '{{ELEMENT_SHA}}':     elem_sha,
    '{{TODAY}}':           today,
}

for entry in manifest.get('seed', {}).get('files', []):
    src = os.path.join(element_dir, entry['from'])
    dst = os.path.join(target, entry['to'])
    policy = entry['policy']

    if policy == 'skip-if-exists' and os.path.exists(dst):
        print(f"    · skip (exists): {entry['to']}")
        continue

    os.makedirs(os.path.dirname(dst), exist_ok=True)

    if policy == 'init-only-with-sha':
        with open(src) as f:
            content = f.read()
        for k, v in subs.items():
            content = content.replace(k, v)
        with open(dst, 'w') as f:
            f.write(content)
        print(f"    · stamp: {entry['to']}")
    elif policy in ('skip-if-exists', 'file-replace'):
        # skip-if-exists already handled the exists case above
        shutil.copy2(src, dst)
        print(f"    · copy: {entry['to']}")
    else:
        print(f"    ⚠ unknown seed.files[] policy: {policy} for {entry['from']}", file=sys.stderr)
PYEOF
fi

echo ""
echo "✓ $ELEMENT_NAME @ $ELEMENT_VERSION installed into $TARGET"
echo "  Lockfile: $TARGET/.claude/rasa.lock.json"
